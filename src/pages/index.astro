---
import Base from '../layouts/Base.astro';
import ProviderCard from '../components/ProviderCard.astro';
import FilterBar from '../components/FilterBar.astro';
import { providers } from '../lib/providers';
import status from '../data/status.json';

const total = providers.length;
let tanggalCek: string | null = null;
if (status.generatedAt) {
  try {
    tanggalCek = new Intl.DateTimeFormat('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(status.generatedAt as string));
  } catch {
    tanggalCek = null;
  }
}

const title = 'modalnol.id — Direktori & Panduan API AI Gratis untuk Developer Indonesia';
const description =
  'Kumpulan API AI gratis (Gemini, Groq, OpenRouter, dll) lengkap dengan panduan daftar berbahasa Indonesia, label konteks Indonesia, dan cek status harian. Dari nol sampai jalan.';
---

<Base title={title} description={description} path="/">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_0%,rgba(16,185,129,0.12),transparent)]"
    >
    </div>
    <div class="mx-auto max-w-5xl px-4 py-16 sm:py-24">
      <p
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent-200 bg-accent-50 px-3 py-1 text-xs font-semibold text-accent-700 dark:border-accent-500/30 dark:bg-accent-500/10 dark:text-accent-400"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
        Modal nol, mulai ngoding AI hari ini
      </p>
      <h1
        class="max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl dark:text-white"
      >
        API AI <span class="text-accent-500">gratis</span> untuk developer Indonesia — dari nol
        sampai jalan.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
        Direktori {total} provider API AI dengan free tier, plus panduan daftar berbahasa Indonesia,
        label konteks lokal (butuh kartu kredit? bisa nomor +62?), dan contoh kode siap
        copy-paste-jalan.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#direktori"
          class="rounded-xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-accent-600"
          >Lihat direktori</a
        >
        <a
          href="/tentang"
          class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 dark:border-slate-700 dark:text-slate-200"
          >Cara kerja situs ini</a
        >
      </div>
      {
        tanggalCek && (
          <p class="mt-6 text-sm text-slate-500">
            ✓ Endpoint provider terakhir dicek otomatis: <strong>{tanggalCek}</strong>
          </p>
        )
      }
    </div>
  </section>

  <!-- Direktori -->
  <section id="direktori" class="mx-auto max-w-5xl scroll-mt-20 px-4 pb-16">
    <div class="mb-6">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
        Direktori provider
      </h2>
      <p class="mt-1 text-slate-600 dark:text-slate-400">
        Filter sesuai kebutuhanmu. Klik kartu untuk panduan lengkap "dari nol sampai jalan".
      </p>
    </div>

    <div class="mb-6">
      <FilterBar />
    </div>

    <div
      id="direktori-grid"
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
    >
      {providers.map((provider) => <ProviderCard provider={provider} />)}
    </div>
  </section>

  <!-- Cara kerja situs ini -->
  <section class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/50">
    <div class="mx-auto max-w-5xl px-4 py-14">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
        Cara kerja situs ini
      </h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-3">
        <div>
          <div class="text-2xl">🩺</div>
          <h3 class="mt-2 font-semibold text-slate-900 dark:text-white">Cek status harian</h3>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Setiap hari sekitar 05.00 WIB, robot kami menyapa endpoint tiap provider untuk memastikan
            layanannya hidup, lalu memberi badge "✓ dicek hari ini".
          </p>
        </div>
        <div>
          <div class="text-2xl">🇮🇩</div>
          <h3 class="mt-2 font-semibold text-slate-900 dark:text-white">Konteks Indonesia</h3>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Tiap provider dilabeli: butuh kartu kredit? bisa daftar pakai nomor +62? kena blokir
            regional? boleh dipakai komersial? Yang belum kami pastikan ditandai jujur "belum
            diverifikasi".
          </p>
        </div>
        <div>
          <div class="text-2xl">📖</div>
          <h3 class="mt-2 font-semibold text-slate-900 dark:text-white">Sumber transparan</h3>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Tiap klaim rate limit menyertakan link ke dokumentasi resmi dan tanggal verifikasi
            manual. Free tier berubah cepat — selalu cek sumber aslinya.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
