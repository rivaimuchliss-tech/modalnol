---
// Badge "konteks Indonesia" — dirender dari providers.json, bukan ditulis manual.
import type { KonteksIndonesia } from '../lib/providers';

export interface Props {
  data: KonteksIndonesia;
  /** "ringkas" untuk kartu, "penuh" untuk halaman detail */
  variant?: 'ringkas' | 'penuh';
}

const { data, variant = 'ringkas' } = Astro.props;

type Tone = 'baik' | 'hati' | 'buruk' | 'netral';

const toneClass: Record<Tone, string> = {
  baik: 'bg-accent-50 text-accent-700 ring-accent-600/20 dark:bg-accent-500/10 dark:text-accent-400 dark:ring-accent-400/20',
  hati: 'bg-amber-50 text-amber-700 ring-amber-600/20 dark:bg-amber-500/10 dark:text-amber-400 dark:ring-amber-400/20',
  buruk: 'bg-rose-50 text-rose-700 ring-rose-600/20 dark:bg-rose-500/10 dark:text-rose-400 dark:ring-rose-400/20',
  netral:
    'bg-slate-100 text-slate-600 ring-slate-500/20 dark:bg-slate-800 dark:text-slate-300 dark:ring-slate-600/30',
};

interface Item {
  label: string;
  ikon: string;
  tone: Tone;
}

// belum diverifikasi (null)
const belum: (label: string) => Item = (label) => ({
  label: `${label}: belum diverifikasi`,
  ikon: '❔',
  tone: 'netral',
});

function kartuKredit(v: boolean | null): Item {
  if (v === null) return belum('Kartu kredit');
  return v
    ? { label: 'Butuh kartu kredit', ikon: '💳', tone: 'hati' }
    : { label: 'Tanpa kartu kredit', ikon: '🚫💳', tone: 'baik' };
}
function nomor(v: boolean | null): Item {
  if (v === null) return belum('Nomor +62');
  return v
    ? { label: 'Bisa daftar pakai nomor +62', ikon: '🇮🇩', tone: 'baik' }
    : { label: 'Nomor +62 tidak didukung', ikon: '📵', tone: 'buruk' };
}
function regional(v: boolean | null): Item {
  if (v === null) return belum('Blokir regional');
  return v
    ? { label: 'Diblokir/​dibatasi di region ID', ikon: '⛔', tone: 'buruk' }
    : { label: 'Bisa diakses dari Indonesia', ikon: '🌏', tone: 'baik' };
}
function komersial(v: boolean | null): Item {
  if (v === null) return belum('Komersial');
  return v
    ? { label: 'Boleh dipakai komersial', ikon: '💼', tone: 'baik' }
    : { label: 'Tidak untuk komersial/produksi', ikon: '🧪', tone: 'hati' };
}

const semua: Item[] = [
  kartuKredit(data.butuhKartuKredit),
  nomor(data.bisaNomorIndonesia),
  regional(data.diblokirRegional),
  komersial(data.bolehKomersial),
];

// Ringkas: hanya tampilkan sinyal paling penting untuk kartu.
const ringkas: Item[] = [
  kartuKredit(data.butuhKartuKredit),
  nomor(data.bisaNomorIndonesia),
];

const items = variant === 'penuh' ? semua : ringkas;
---

<ul class={variant === 'penuh' ? 'flex flex-wrap gap-2' : 'flex flex-wrap gap-1.5'}>
  {
    items.map((it) => (
      <li
        class:list={[
          'inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset',
          toneClass[it.tone],
        ]}
      >
        <span aria-hidden="true">{it.ikon}</span>
        <span>{it.label}</span>
      </li>
    ))
  }
</ul>

{
  variant === 'penuh' && data.catatan && (
    <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
      <strong class="font-semibold">Catatan:</strong> {data.catatan}
    </p>
  )
}
