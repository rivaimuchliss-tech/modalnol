---
import type { Provider } from '../lib/providers';
import { LABEL_KATEGORI } from '../lib/providers';
import StatusBadge from './StatusBadge.astro';
import IndoBadges from './IndoBadges.astro';

export interface Props {
  provider: Provider;
}

const { provider } = Astro.props;
const k = provider.konteksIndonesia;

// Atribut data untuk filter client-side (string agar mudah dibaca JS).
const dataKategori = provider.kategori.join(',');
const tanpaCC = k.butuhKartuKredit === false ? 'ya' : 'tidak';
const komersial = k.bolehKomersial === true ? 'ya' : 'tidak';
---

<article
  class="provider-card group relative flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-accent-400 hover:shadow-lg hover:shadow-accent-500/5 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-accent-500/50"
  data-kategori={dataKategori}
  data-tanpa-cc={tanpaCC}
  data-komersial={komersial}
  data-nama={provider.nama.toLowerCase()}
>
  <div class="mb-2 flex items-start justify-between gap-2">
    <h3 class="text-lg font-bold tracking-tight text-slate-900 dark:text-white">
      <a href={`/provider/${provider.slug}`} class="after:absolute after:inset-0">
        {provider.nama}
      </a>
    </h3>
    <StatusBadge slug={provider.slug} />
  </div>

  <p class="mb-3 line-clamp-2 text-sm text-slate-600 dark:text-slate-400">
    {provider.deskripsi}
  </p>

  <div class="mb-3 flex flex-wrap gap-1.5">
    {
      provider.kategori.map((kat) => (
        <span class="rounded-md bg-slate-100 px-1.5 py-0.5 text-[11px] font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
          {LABEL_KATEGORI[kat]}
        </span>
      ))
    }
    {
      provider.kompatibelOpenAI && (
        <span class="rounded-md bg-accent-50 px-1.5 py-0.5 text-[11px] font-medium text-accent-700 dark:bg-accent-500/10 dark:text-accent-400">
          OpenAI-compatible
        </span>
      )
    }
  </div>

  <div class="mt-auto pt-2">
    <IndoBadges data={k} variant="ringkas" />
  </div>
</article>
