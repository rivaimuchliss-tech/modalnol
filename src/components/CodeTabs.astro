---
// Tab contoh kode. Pakai named slot: <CodeTabs><Fragment slot="python">…</Fragment>…</CodeTabs>
// Isi slot idealnya <pre><code>…</code></pre> (mis. hasil highlight Shiki).
const id = 'ct-' + Math.round(Astro.props.seed ?? 0).toString(36) + '-' + (Astro.props.slug ?? 'x');
export interface Props {
  slug?: string;
  seed?: number;
}
---

<div class="code-tabs my-5 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800" data-codetabs>
  <div class="flex border-b border-slate-200 bg-slate-100 text-sm font-medium dark:border-slate-800 dark:bg-slate-900">
    <button type="button" class="ct-tab is-active px-4 py-2" data-target="python">Python</button>
    <button type="button" class="ct-tab px-4 py-2" data-target="javascript">JavaScript</button>
  </div>
  <div class="ct-panel" data-panel="python" id={`${id}-python`}>
    <slot name="python" />
  </div>
  <div class="ct-panel hidden" data-panel="javascript" id={`${id}-javascript`}>
    <slot name="javascript" />
  </div>
</div>

<script>
  for (const box of document.querySelectorAll<HTMLElement>('[data-codetabs]')) {
    const tabs = box.querySelectorAll<HTMLButtonElement>('.ct-tab');
    const panels = box.querySelectorAll<HTMLElement>('.ct-panel');
    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        for (const t of tabs) t.classList.toggle('is-active', t === tab);
        for (const p of panels) p.classList.toggle('hidden', p.dataset.panel !== target);
      });
    }
  }
</script>

<style>
  .ct-tab {
    color: rgb(100 116 139);
    border-bottom: 2px solid transparent;
  }
  .ct-tab.is-active {
    color: var(--color-accent-600, #059669);
    border-bottom-color: var(--color-accent-500, #10b981);
    background: #fff;
  }
  @media (prefers-color-scheme: dark) {
    .ct-tab.is-active {
      background: rgb(2 6 23);
      color: var(--color-accent-400, #34d399);
    }
  }
</style>
